# Data — never commit raw/processed astronomical data
data/raw/*
data/processed/*
renders/*

# Keep directory skeletons so scripts can write to them after a fresh clone
!data/raw/.gitkeep
!data/processed/.gitkeep
!renders/frames/
renders/frames/*
!renders/frames/.gitkeep
!renders/segments/
renders/segments/*
!renders/segments/.gitkeep

# Web build artifacts
web/dist/
web/node_modules/

# Web public data (generated by pipeline)
web/public/data/*.bin
web/public/data/metadata.json

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
.eggs/

# Blender temp files
*.blend1
*.blend2

# macOS
.DS_Store
.AppleDouble

# mise local overrides
.mise.local.toml

# Editors
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
